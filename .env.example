# YouTube to Ebook - Environment Variables
# Copy this file to .env and fill in your keys

# YouTube Data API Key (free from Google Cloud Console)
# Get it at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API Key (from Google AI Studio)
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail credentials (optional - for email delivery)
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# Azure Text-to-Speech (Free Tier)
# Get key and region from Azure Portal: https://portal.azure.com/
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=koreacentral
# Optional: Customize voices (defaults shown)
AZURE_TTS_VOICE_EN=en-US-JennyNeural
AZURE_TTS_VOICE_KO=ko-KR-SeoHyeonNeural

# Optional: Adjust Speaking Rate (default: 1.0)
# English: 0.8 (slower), Korean: 1.5 (faster)
AZURE_TTS_RATE_EN=0.8
AZURE_TTS_RATE_KO=1.5

# NotebookLM Podcast (optional - conversational AI podcast)
# Install: pip install notebooklm-mcp-cli && nlm login
# If configured, podcast generation takes priority over Azure TTS.
# NOTEBOOKLM_PODCAST_FORMAT=deep_dive   # deep_dive, brief, critique, debate
# NOTEBOOKLM_PODCAST_LENGTH=default     # short, default, long

# Cloudflare R2 (optional - for archive audio hosting)
# Create a bucket and API token at: https://dash.cloudflare.com/ → R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=youtube-digest-audio
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Archive site repo path (For web archive export)
# Since using a monorepo approach, point this to the youtube-digest-archive folder inside this project.
# Example: C:\Users\user\Downloads\youtube-to-ebook\youtube-digest-archive
ARCHIVE_REPO_PATH=
