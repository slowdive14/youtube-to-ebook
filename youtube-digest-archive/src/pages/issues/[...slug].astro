---
// src/pages/issues/[...slug].astro
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const issues = await getCollection('issues');
	return issues.map(issue => ({
		params: { slug: issue.id },
		props: { issue },
	}));
}

const { issue } = Astro.props;
const { Content } = await render(issue);

// Format date nicely
const dateObj = new Date(issue.data.date);
const formattedDate = dateObj.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric'
});
const isKorean = issue.data.subject.match(/[가-힣]/);
---

<BaseLayout title={`${issue.data.title} - YouTube Digest`}>
	<nav id="toc-sidebar" class="toc-sidebar" aria-label="Table of Contents">
		<div class="toc-title"><a href="/">&larr; Archive</a></div>
		<ul id="toc-list"></ul>
	</nav>

	<!-- Mobile TOC (visible at <= 1200px) -->
	<div id="mobile-toc" class="mobile-toc">
		<div class="mobile-toc-header">
			<a href="/" class="mobile-archive-btn" aria-label="Back to Archive">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
			</a>
			<button id="mobile-toc-bar" class="mobile-toc-bar" aria-expanded="false" aria-controls="mobile-toc-dropdown">
				<span id="mobile-toc-current" class="mobile-toc-current">Contents</span>
				<svg class="mobile-toc-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 6 8 10 12 6"></polyline></svg>
			</button>
		</div>
		<div class="mobile-toc-progress" id="mobile-toc-progress"></div>
		<div id="mobile-toc-dropdown" class="mobile-toc-dropdown" role="navigation" hidden>
			<ul id="mobile-toc-list" class="mobile-toc-list"></ul>
		</div>
	</div>
	<div id="mobile-toc-backdrop" class="mobile-toc-backdrop" hidden></div>

	<article class="issue-container">
		<header class="issue-header">
			<h1>{isKorean ? "YouTube 다이제스트" : "YouTube Digest"}</h1>
			<div class="date">{formattedDate}</div>
		</header>

		{issue.data.audioUrls && issue.data.audioUrls.length > 0 && (
			<div class="audio-player-container">
				<h3 class="audio-header">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
					Listen to this issue
				</h3>
				
				{issue.data.audioUrls.map((url, i) => (
					<div class="audio-part">
						{issue.data.audioUrls!.length > 1 && (
							<div style="font-size: 14px; color: var(--text-muted); margin-bottom: 5px;">Part {i + 1}</div>
						)}
						<audio controls preload="metadata">
							<source src={url} type="audio/mpeg" />
							Your browser does not support the audio element.
						</audio>
					</div>
				))}
			</div>
		)}

		{issue.data.drillSentences && issue.data.drillSentences.length > 0 && (
			<div class="drill-link-container">
				<a href={`/drill/${issue.id}`} class="drill-link-btn">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
						<path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
						<line x1="12" y1="19" x2="12" y2="23"/>
						<line x1="8" y1="23" x2="16" y2="23"/>
					</svg>
					Speaking Drill ({issue.data.drillSentences.length} sentences)
				</a>
			</div>
		)}

		<div class="markdown-content">
			<Content />
		</div>
	</article>

	<!-- Dictionary lookup popup -->
	<button id="dict-trigger" class="dict-trigger" hidden aria-label="Look up definition">
		<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
		<span>사전</span>
	</button>
	<div id="dict-popup" class="dict-popup" hidden>
		<div class="dict-popup-header">
			<span id="dict-popup-word" class="dict-popup-word"></span>
			<button id="dict-popup-close" class="dict-popup-close" aria-label="Close">&times;</button>
		</div>
		<div id="dict-popup-body" class="dict-popup-body"></div>
	</div>
</BaseLayout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const content = document.querySelector('.markdown-content');
		if (!content) return;

		const headings = Array.from(content.querySelectorAll('h1, h2, h3'));
		if (headings.length < 2) return;

		// === Phase 1: Shared data model ===
		const tocData = headings.map((heading, i) => {
			if (!heading.id) heading.id = 'heading-' + i;
			return {
				el: heading,
				id: heading.id,
				level: parseInt(heading.tagName[1]),
				text: heading.textContent.trim(),
			};
		});

		// === Phase 2: Desktop TOC (sidebar) ===
		const tocList = document.getElementById('toc-list');
		const tocSidebar = document.getElementById('toc-sidebar');
		const desktopLinks = [];

		if (tocList && tocSidebar) {
			tocData.forEach((item) => {
				const li = document.createElement('li');
				li.className = 'toc-item toc-level-' + item.level;
				const a = document.createElement('a');
				a.href = '#' + item.id;
				a.textContent = item.text;
				a.dataset.target = item.id;
				li.appendChild(a);
				tocList.appendChild(li);
				desktopLinks.push(a);
			});
		}

		// === Phase 3: Mobile TOC (grouped, collapsible) ===
		const mobileToc = document.getElementById('mobile-toc');
		const mobileBar = document.getElementById('mobile-toc-bar');
		const mobileCurrent = document.getElementById('mobile-toc-current');
		const mobileDropdown = document.getElementById('mobile-toc-dropdown');
		const mobileList = document.getElementById('mobile-toc-list');
		const mobileBackdrop = document.getElementById('mobile-toc-backdrop');
		const mobileProgress = document.getElementById('mobile-toc-progress');

		const isLanguageDivider = (item) =>
			item.level === 2 && /^(English|한국어)$/i.test(item.text);

		if (mobileList) {
			let currentGroupUl = null;

			tocData.forEach((item) => {
				if (isLanguageDivider(item)) {
					// Language divider: sticky sub-header
					const dividerLi = document.createElement('li');
					dividerLi.className = 'mtoc-lang-divider';
					dividerLi.textContent = item.text;
					dividerLi.dataset.headingId = item.id;
					mobileList.appendChild(dividerLi);
					currentGroupUl = null;
					return;
				}

				if (item.level === 1) {
					// Article title: collapsible group header
					const groupLi = document.createElement('li');
					groupLi.className = 'mtoc-group';

					const toggle = document.createElement('button');
					toggle.className = 'mtoc-group-toggle';
					toggle.setAttribute('aria-expanded', 'false');

					const chevron = document.createElement('span');
					chevron.className = 'mtoc-chevron';
					chevron.innerHTML = '<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 4 10 8 6 12"></polyline></svg>';

					const link = document.createElement('a');
					link.href = '#' + item.id;
					link.className = 'mtoc-link mtoc-link-h1';
					link.dataset.headingId = item.id;
					link.textContent = item.text;

					toggle.appendChild(chevron);
					toggle.appendChild(link);
					groupLi.appendChild(toggle);

					const childUl = document.createElement('ul');
					childUl.className = 'mtoc-children';
					childUl.hidden = true;
					groupLi.appendChild(childUl);

					mobileList.appendChild(groupLi);
					currentGroupUl = childUl;

					// Toggle expand/collapse (but not when clicking the link)
					toggle.addEventListener('click', (e) => {
						if (e.target.closest('a')) return;
						e.preventDefault();
						const expanded = toggle.getAttribute('aria-expanded') === 'true';
						toggle.setAttribute('aria-expanded', String(!expanded));
						childUl.hidden = expanded;
					});
					return;
				}

				// h2 or h3: child inside current group
				if (currentGroupUl) {
					const childLi = document.createElement('li');
					childLi.className = item.level === 2 ? 'mtoc-child mtoc-child-h2' : 'mtoc-child mtoc-child-h3';
					const a = document.createElement('a');
					a.href = '#' + item.id;
					a.className = 'mtoc-link';
					a.dataset.headingId = item.id;
					a.textContent = item.text;
					childLi.appendChild(a);
					currentGroupUl.appendChild(childLi);
				}
			});
		}

		// === Phase 4: Shared IntersectionObserver ===
		let activeDesktopLink = null;

		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (!entry.isIntersecting) return;
				const id = entry.target.id;

				// Desktop: highlight active link
				if (activeDesktopLink) activeDesktopLink.classList.remove('toc-active');
				const dLink = desktopLinks.find(a => a.dataset.target === id);
				if (dLink) {
					dLink.classList.add('toc-active');
					activeDesktopLink = dLink;
					dLink.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
				}

				// Mobile: update bar text (nearest h1 ancestor)
				if (mobileCurrent) {
					const activeIndex = tocData.findIndex(t => t.id === id);
					let articleTitle = 'Contents';
					for (let j = activeIndex; j >= 0; j--) {
						if (tocData[j].level === 1) {
							articleTitle = tocData[j].text;
							break;
						}
					}
					mobileCurrent.textContent = articleTitle;
				}

				// Mobile: highlight active + auto-expand group
				if (mobileList) {
					mobileList.querySelectorAll('.mtoc-link').forEach(a => a.classList.remove('mtoc-active'));
					const mLink = mobileList.querySelector(`[data-heading-id="${CSS.escape(id)}"]`);
					if (mLink) {
						mLink.classList.add('mtoc-active');
						const group = mLink.closest('.mtoc-group');
						if (group) {
							const toggle = group.querySelector('.mtoc-group-toggle');
							const children = group.querySelector('.mtoc-children');
							if (toggle && children) {
								toggle.setAttribute('aria-expanded', 'true');
								children.hidden = false;
							}
						}
					}
				}
			});
		}, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });

		tocData.forEach(item => observer.observe(item.el));

		// === Phase 5: Mobile dropdown open/close ===
		let isDropdownOpen = false;

		function openDropdown() {
			isDropdownOpen = true;
			mobileDropdown.hidden = false;
			mobileBackdrop.hidden = false;
			mobileBar.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
			requestAnimationFrame(() => {
				const active = mobileList.querySelector('.mtoc-active');
				if (active) active.scrollIntoView({ block: 'center', behavior: 'instant' });
			});
		}

		function closeDropdown() {
			isDropdownOpen = false;
			mobileDropdown.hidden = true;
			mobileBackdrop.hidden = true;
			mobileBar.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		}

		if (mobileBar) {
			mobileBar.addEventListener('click', () => {
				isDropdownOpen ? closeDropdown() : openDropdown();
			});
		}
		if (mobileBackdrop) {
			mobileBackdrop.addEventListener('click', closeDropdown);
		}

		// Event delegation: handle all heading link clicks in mobile TOC
		if (mobileList) {
			mobileList.addEventListener('click', (e) => {
				const link = e.target.closest('a.mtoc-link');
				if (link) {
					e.preventDefault();
					closeDropdown();
					const targetId = link.dataset.headingId;
					const targetEl = document.getElementById(targetId);
					if (targetEl) {
						const y = targetEl.getBoundingClientRect().top + window.scrollY - 52;
						window.scrollTo({ top: y, behavior: 'smooth' });
					}
				}
			});
		}

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && isDropdownOpen) closeDropdown();
		});

		// === Phase 6: Reading progress bar ===
		if (mobileProgress) {
			window.addEventListener('scroll', () => {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
				mobileProgress.style.width = (progress * 100) + '%';
			}, { passive: true });
		}
	});
</script>

<script>
	// === Dictionary Lookup (text selection → Gemini API) ===
	document.addEventListener('DOMContentLoaded', () => {
		const content = document.querySelector('.markdown-content');
		if (!content) return;

		const trigger = document.getElementById('dict-trigger');
		const popup = document.getElementById('dict-popup');
		const popupWord = document.getElementById('dict-popup-word');
		const popupBody = document.getElementById('dict-popup-body');
		const popupClose = document.getElementById('dict-popup-close');
		if (!trigger || !popup || !popupWord || !popupBody || !popupClose) return;

		let currentSelection = '';
		let triggerTimer = null;

		function hideTrigger() {
			trigger.hidden = true;
			if (triggerTimer) { clearTimeout(triggerTimer); triggerTimer = null; }
		}

		function showTriggerForSelection() {
			const sel = window.getSelection();
			if (!sel || sel.isCollapsed || !sel.toString().trim()) return;
			if (!popup.hidden) return;

			const text = sel.toString().trim();
			if (!content.contains(sel.anchorNode)) return;
			if (text.length > 500 || text.length < 1) return;

			currentSelection = text;
			const range = sel.getRangeAt(0);
			const rect = range.getBoundingClientRect();

			trigger.hidden = false;
			trigger.style.top = (rect.bottom + window.scrollY + 8) + 'px';
			trigger.style.left = Math.min(
				rect.left + rect.width / 2 - 30,
				window.innerWidth - 80
			) + 'px';

			// Auto-hide after 3 seconds
			if (triggerTimer) clearTimeout(triggerTimer);
			triggerTimer = setTimeout(hideTrigger, 3000);
		}

		// Show on mouseup (desktop) and touchend (mobile) — fires once per selection
		content.addEventListener('mouseup', () => setTimeout(showTriggerForSelection, 50));
		content.addEventListener('touchend', () => setTimeout(showTriggerForSelection, 50));

		// Hide on scroll, click outside, or new touch
		document.addEventListener('scroll', hideTrigger, { passive: true });
		document.addEventListener('touchstart', (e) => {
			if (!trigger.contains(e.target)) hideTrigger();
		}, { passive: true });

		// Get surrounding context for better AI understanding
		function getContext(sel) {
			if (!sel.anchorNode) return '';
			const p = sel.anchorNode.parentElement?.closest('p, li, blockquote, h1, h2, h3');
			if (!p) return '';
			const fullText = p.textContent || '';
			return fullText.length > 300 ? fullText.substring(0, 300) + '...' : fullText;
		}

		// Handle trigger click → fetch from API
		trigger.addEventListener('click', async (e) => {
			e.preventDefault();
			e.stopPropagation();
			if (!currentSelection) return;

			const sel = window.getSelection();
			const context = sel ? getContext(sel) : '';

			// Position popup
			const triggerRect = trigger.getBoundingClientRect();
			popup.hidden = false;
			popup.style.top = (triggerRect.bottom + window.scrollY + 8) + 'px';
			popup.style.left = Math.max(8, Math.min(
				triggerRect.left + triggerRect.width / 2 - 160,
				window.innerWidth - 328
			)) + 'px';

			const displayText = currentSelection.length > 40
				? currentSelection.substring(0, 40) + '...'
				: currentSelection;
			popupWord.textContent = displayText;
			popupBody.innerHTML = '<div class="dict-loading"><span class="dict-spinner"></span> 검색 중...</div>';

			hideTrigger();

			try {
				const res = await fetch('/api/define', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ text: currentSelection, context }),
				});

				if (!res.ok) {
					const err = await res.json();
					popupBody.textContent = err.error || '오류가 발생했습니다';
					return;
				}

				const data = await res.json();
				// Parse the structured response into HTML
				const lines = data.result.split('\n').filter(l => l.trim());
				popupBody.innerHTML = lines.map(line => {
					const match = line.match(/^\[(.+?)\]\s*(.+)/);
					if (match) {
						return `<div class="dict-entry"><span class="dict-label">${match[1]}</span> ${match[2]}</div>`;
					}
					return `<div class="dict-entry">${line}</div>`;
				}).join('');
			} catch {
				popupBody.textContent = '네트워크 오류. 다시 시도해주세요.';
			}
		});

		// Close popup and clear selection
		function closePopup() {
			popup.hidden = true;
			hideTrigger();
			currentSelection = '';
			window.getSelection()?.removeAllRanges();
		}

		popupClose.addEventListener('click', closePopup);

		document.addEventListener('click', (e) => {
			if (!popup.hidden && !popup.contains(e.target) && e.target !== trigger && !trigger.contains(e.target)) {
				closePopup();
			}
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !popup.hidden) closePopup();
		});
	});
</script>
