---
// src/pages/issues/[slug]/read.astro
// A clean, stripped-down reader page optimized for Chrome's "Listen to this page"
// No navigation, no audio player, no dictionary popup - just pure article text.
import { getCollection } from 'astro:content';
import { marked } from 'marked';

export async function getStaticPaths() {
	const issues = await getCollection('issues');
	return issues.map(issue => ({
		params: { slug: issue.id },
		props: { issue },
	}));
}

const { issue } = Astro.props;

// Split by '## 한국어' to extract only the English part
let englishBody = issue.body;
if (englishBody.includes('## 한국어')) {
	englishBody = englishBody.split('## 한국어')[0];
}

// Convert markdown to HTML on the server
const contentHtml = marked.parse(englishBody);

const dateObj = new Date(issue.data.date);
const formattedDate = dateObj.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric'
});
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={issue.data.subject} />
	<title>{issue.data.subject} - YouTube Digest</title>
	<style>
		@import url('https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,400&family=Inter:wght@400;500;600&display=swap');

		* { margin: 0; padding: 0; box-sizing: border-box; }

		body {
			font-family: 'Merriweather', Georgia, serif;
			font-size: 18px;
			line-height: 1.9;
			color: #1a1a1a;
			background: #fafaf7;
			max-width: 720px;
			margin: 0 auto;
			padding: 2rem 1.5rem;
		}

		header {
			text-align: center;
			padding: 1.5rem 0 2rem;
			border-bottom: 3px double #e0e0e0;
			margin-bottom: 2rem;
		}

		header h1 {
			font-family: 'Inter', sans-serif;
			font-size: 1.8rem;
			font-weight: 600;
			margin-bottom: 0.3rem;
		}

		header time {
			font-family: 'Inter', sans-serif;
			font-size: 0.9rem;
			color: #777;
		}

		article {
			/* Main readable content */
		}

		article h2 {
			font-size: 1.5rem;
			margin: 2.5rem 0 1rem;
			line-height: 1.3;
			border-bottom: 1px solid #eee;
			padding-bottom: 0.3rem;
		}

		article h3 {
			font-size: 1.2rem;
			margin: 2rem 0 0.8rem;
		}

		article h4 {
			font-size: 1.05rem;
			margin: 1.5rem 0 0.6rem;
		}

		article p {
			margin-bottom: 1.2em;
		}

		article blockquote {
			border-left: 4px solid #c9302c;
			padding: 0.8rem 1.2rem;
			margin: 1.5rem 0;
			background: #f5f5f0;
			font-style: italic;
			color: #555;
		}

		article ul, article ol {
			margin: 1rem 0;
			padding-left: 1.8rem;
		}

		article li {
			margin-bottom: 0.6em;
		}

		article strong {
			color: #111;
		}

		article a {
			color: #c9302c;
			text-decoration: none;
		}

		article hr {
			border: none;
			border-top: 2px solid #e0e0e0;
			margin: 3rem 0;
		}

		footer {
			text-align: center;
			padding: 2rem 0 1rem;
			border-top: 1px solid #e0e0e0;
			margin-top: 3rem;
			font-family: 'Inter', sans-serif;
			font-size: 0.85rem;
			color: #999;
		}

		footer a {
			color: #c9302c;
			text-decoration: none;
		}
	</style>
</head>
<body>
	<header>
		<h1>YouTube Digest</h1>
		<time datetime={issue.data.date.toISOString().split('T')[0]}>{formattedDate}</time>
	</header>

	<article set:html={contentHtml} />

	<footer>
		<a href={`/issues/${issue.id}`}>&larr; Back to full version</a>
	</footer>
</body>
</html>
